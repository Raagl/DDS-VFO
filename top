library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity top is
    port (
        clk  : in std_logic;
        rst  : in std_logic;
        RX   : in std_logic; -- Physical UART Input
        WAVE : out std_logic_vector(7 downto 0) -- To R-2R Ladder
    );
end top;

architecture Behavioral of top is
    signal freq_in_wire  : unsigned(31 downto 0) := (others => '0');
    signal running_total : unsigned(31 downto 0) := (others => '0');
    signal dds_result    : std_logic_vector(7 downto 0);

    signal rx_byte_wire  : std_logic_vector(7 downto 0);
    signal rx_avail_wire : std_logic;

begin
    WAVE <= dds_result;

    U_DDS : entity work.dds 
        port map (
            clk     => clk,
            rst     => rst,
            freq_in => std_logic_vector(freq_in_wire),
            WAVE    => dds_result
        );
    
    U_RX : entity work.rx_mod 
        generic map (CLK_PER_BIT => 434)
        port map (
            clk        => clk,
            rst        => rst,
            I_RX       => RX,
            DATA_AVAIL => rx_avail_wire,
            DATA_BYTE  => rx_byte_wire
        );

    ASCII_PRO : process (clk, rst)
        variable digit_var : integer;
    begin
        if rst = '1' then
            running_total <= (others => '0');
            freq_in_wire  <= (others => '0');
        elsif rising_edge(clk) then 
            if rx_avail_wire = '1' then
                -- Build frequency from '0'-'9'
                if rx_byte_wire >= x"30" and rx_byte_wire <= x"39" then
                    digit_var := to_integer(unsigned(rx_byte_wire) - x"30");
                    running_total <= (running_total * 10) + to_unsigned(digit_var, 32);
                                     
                -- Latch on 'Enter'
                elsif rx_byte_wire = x"0D" or rx_byte_wire = x"0A" then
                    freq_in_wire  <= running_total;
                    running_total <= (others => '0');
                end if;
            end if;
        end if;
    end process;
end Behavioral;
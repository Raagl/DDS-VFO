library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity top is
    port (
        clk  : in std_logic;
        rst  : in std_logic;
        vauxp6 : in  std_logic; -- J3
        vauxn6 : in  std_logic; -- K3
        WAVE : out std_logic_vector(9 downto 0) -- To R-2R Ladder
    );
end top;

architecture Behavioral of top is
    -- XADC Signals
    signal xadc_do    : std_logic_vector(15 downto 0);
    signal xadc_drdy  : std_logic;
    
    -- DDS Signals
    signal phase_inc_reg  : unsigned(31 downto 0) := (others => '0');
    signal y1_out_reg  : std_logic_vector(9 downto 0);
    signal y2_out_reg  : std_logic_vector(9 downto 0);
    signal sign_bit2_reg : std_logic;
    signal frac_bit2_reg : std_logic_vector(3 downto 0);
    signal dds_result    : std_logic_vector(9 downto 0);

     -- Add this to your architecture signals
    signal interp_res : unsigned(14 downto 0); -- 10 bits + 4 bits frac + 1 bit sum
    signal final_wave : unsigned(9 downto 0);

    -- Potentiometer Scale Constant
    -- Scaling math 
    -- Freq_Resolution = Freq_Clock / 2^32 = 100MHz / 4,294,967,296 = 0.0233 Hz
    -- Multiplier = Desired_Freq / (ADC_Max * Freq_Resolution) = 20,000 / (4095 * 0.0233) = 209.6 ~ 210 for better resolution
    -- Knob range = 0 - 20 KHz
    -- ADC range = 0 - 4095
    
    component xadc_wiz_0 is 
        port
        (
            daddr_in        : in  STD_LOGIC_VECTOR (6 downto 0);     -- Address bus for the dynamic reconfiguration port
            den_in          : in  STD_LOGIC;                         -- Enable Signal for the dynamic reconfiguration port
            di_in           : in  STD_LOGIC_VECTOR (15 downto 0);    -- Input data bus for the dynamic reconfiguration port
            dwe_in          : in  STD_LOGIC;                         -- Write Enable for the dynamic reconfiguration port
            do_out          : out  STD_LOGIC_VECTOR (15 downto 0);   -- Output data bus for dynamic reconfiguration port
            drdy_out        : out  STD_LOGIC;                        -- Data ready signal for the dynamic reconfiguration port
            dclk_in         : in  STD_LOGIC;                         -- Clock input for the dynamic reconfiguration port
            reset_in        : in  STD_LOGIC;                         -- Reset signal for the System Monitor control logic
            vauxp6          : in  STD_LOGIC;                         -- Auxiliary Channel 6
            vauxn6          : in  STD_LOGIC;
            busy_out        : out  STD_LOGIC;                        -- ADC Busy signal
            channel_out     : out  STD_LOGIC_VECTOR (4 downto 0);    -- Channel Selection Outputs
            eoc_out         : out  STD_LOGIC;                        -- End of Conversion Signal
            eos_out         : out  STD_LOGIC;                        -- End of Sequence Signal
            vccaux_alarm_out : out  STD_LOGIC;                        -- VCCAUX-sensor alarm output
            vccint_alarm_out : out  STD_LOGIC;                        -- VCCINT-sensor alarm output
            user_temp_alarm_out : out  STD_LOGIC;                        -- Temperature-sensor alarm output
            alarm_out       : out STD_LOGIC;                         -- OR'ed output of all the Alarms
            vp_in           : in  STD_LOGIC;                         -- Dedicated Analog Input Pair
            vn_in           : in  STD_LOGIC
        );
        end component;

begin
    WAVE <= dds_result;

    U_DDS : entity work.dds 
        port map (
            clk     => clk,
            rst     => rst,
            phase_inc => std_logic_vector(phase_inc_reg),
            y1_out      => y1_out_reg, -- Current sample from LUT
            y2_out      => y2_out_reg, -- Next sample from LUT for interpolation
            sign_bit2   => sign_bit2_reg, -- Delayed sign bit for output inversion
            frac_bit2   => frac_bit2_reg   -- Delayed fractional bits for interpolation
        );

    U_XADC : xadc_wiz_0
        port map (
            daddr_in            => "0010110",     -- Address bus for the dynamic reconfiguration port
            den_in              => '1',            -- Enable Signal for the dynamic reconfiguration port
            di_in               => (others => '0'),-- Input data bus for the dynamic reconfiguration port
            dwe_in              => '0',            -- Write Enable for the dynamic reconfiguration port
            do_out              => xadc_do,        -- Output data bus for dynamic reconfiguration port
            drdy_out            => xadc_drdy,      -- Data ready signal for the dynamic reconfiguration port
            dclk_in             => clk,            -- Clock input for the dynamic reconfiguration port
            reset_in            => rst,            -- Reset signal for the System Monitor control logic
            vauxp6              => vauxp6,         -- Auxiliary Channel 6
            vauxn6              => vauxn6,
            busy_out            => open,           -- ADC Busy signal
            channel_out         => open,           -- Channel Selection Outputs
            eoc_out             => open,           -- End of Conversion Signal
            eos_out             => open,           -- End of Sequence Signal
            vccaux_alarm_out    => open,           -- VCCAUX-sensor alarm output
            vccint_alarm_out    => open,           -- VCCINT-sensor alarm output
            user_temp_alarm_out => open,           -- Temperature-sensor alarm output
            alarm_out           => open,           -- OR'ed output of all the Alarms
            vp_in               => '0',            -- Dedicated Analog Input Pair
            vn_in               => '0'
        );

    -- Connect the final result to the output port
    WAVE <= dds_result;

    -- INTERPOLATION AND SYMMETRY PROCESS
    MATH_PROC : process(clk)
        variable weight1 : unsigned(4 downto 0);
        variable weight2 : unsigned(3 downto 0);
        variable prod1   : unsigned(14 downto 0);
        variable prod2   : unsigned(14 downto 0);
        variable combined : unsigned(14 downto 0);
    begin
        if rising_edge(clk) then
            -- Calculate weights (16 - frac) and (frac)
            weight1 := 16 - unsigned('0' & frac_bit2_reg);
            weight2 := unsigned(frac_bit2_reg);

            prod1 := unsigned(y1_out_reg) * weight1;
            prod2 := resize (unsigned(y2_out_reg) * weight2, 15);

            combined := prod1 + prod2;
            final_wave <= combined(13 downto 4);

            -- Second Symmetry: Invert for 180-360 degrees
            -- If sign_bit is '1', we are in the bottom half of the circle
            if sign_bit2_reg = '1' then
                -- 1023 is the max 10-bit value
                dds_result <= std_logic_vector(1023 - final_wave);
            else
                dds_result <= std_logic_vector(final_wave);
            end if;
        end if;
    end process;

    POTENTIOMETER_PROC : process(clk)
        variable raw_adc : unsigned(11 downto 0);
        constant SCALE_FACTOR : unsigned (15 downto 0) := TO_UNSIGNED(210, 16);
    begin
        if rising_edge(clk) then
            if xadc_drdy = '1' then
                -- 12 bit Potentiometer reading from XADC (0-4095)
                raw_adc := unsigned(xadc_do(15 downto 4));
                -- Scaling math 
                -- Freq_Resolution = Freq_Clock / 2^32 = 100MHz / 4,294,967,296 = 0.0233 Hz
                -- Multiplier = Desired_Freq / (ADC_Max * Freq_Resolution) = 20,000 / (4095 * 0.0233) = 209.6 ~ 210 for better resolution
                -- Knob range = 0 - 20 KHz
                -- ADC range = 0 - 4095
                phase_inc_reg <= resize(raw_adc * SCALE_FACTOR, 32);
                end if;
            end if;
    end process;
end Behavioral;
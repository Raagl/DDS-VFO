-- DDS (Direct Digital Synthesizer) Implementation in VHDL
-- First Symmetry: Use LUT for 0 to 90 degrees, mirror for 90 to 180
-- Second Symmetry: Use sign bit to invert output for 180 to 360 degrees
-- 2 stage pipeline: Accumulator Update, BRAM Read
-- 32 bit phase accumulator, 512 x 10 bit BRAM
-- Dual port BRAM for interpolation, send current and next address
library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity dds is
    port (
        clk         : in std_logic;
        rst         : in std_logic;
        phase_inc   : in std_logic_vector(31 downto 0);
        y1_out      : out std_logic_vector(9 downto 0); -- Current sample from LUT
        y2_out      : out std_logic_vector(9 downto 0); -- Next sample from LUT for interpolation
        sign_bit2   : out std_logic;                    -- Delayed sign bit for output inversion
        frac_bit2   : out std_logic_vector(3 downto 0)  -- Delayed fractional bits for interpolation
    );
end dds;

architecture nco of dds is

    -- Internal Signals
    signal phase_accumulator : unsigned(31 downto 0) := (others => '0');

    -- Signals for pipelining
    signal sign_bit1 : std_logic; -- Top bit of phase accumulator for 180 degree symmetry
    signal frac_bit1 : std_logic_vector(3 downto 0); -- 4-bit Fractional bit for interpolation

    -- Signals for BRAM read address
    signal addr1 : integer range 0 to 511; -- Address for current sample
    signal addr2 : integer range 0 to 511; -- Address for next sample (for interpolation)
    
    -- BRAM (512 x 10 bits) for sine wave samples, only 1024 unique values due to symmetry
    type LUT_TYPE is array(0 to 511) of integer range 0 to 1023;
    constant sine_lut : LUT_TYPE := (
        0,    3,    6,    9,   13,   16,   19,   22, 
        25,   28,   31,   35,   38,   41,   44,   47, 
        50,   53,   57,   60,   63,   66,   69,   72, 

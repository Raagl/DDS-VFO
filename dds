        1023, 1023, 1023, 1023, 1023, 1023, 1023, 1023
    );
begin      
    ACCUMULATOR_PROC : process(clk)
        variable current_idx : unsigned(8 downto 0);
    begin
        if rising_edge(clk) then
            if rst = '1' then
                phase_accumulator <= (others => '0');
            else
                phase_accumulator <= phase_accumulator + unsigned(phase_inc);
                current_idx := phase_accumulator(29 downto 21); -- Take the top 9 bits after the sign bit for LUT address
                -- First symmetry: Use LUT for 0 to 90 degrees if '1', else mirror for 90 to 180
                if phase_accumulator(30) = '1' then
                    addr1 <= to_integer(not current_idx); --take 9 bits for 512 entry LUT, invert for 90-180 degree range
                    addr2 <= to_integer(not current_idx - 1); --next address for interpolation    
                else
                    addr1 <= to_integer(current_idx);
                    addr2 <= to_integer(current_idx + 1);
                end if;

                -- Pipelining for BRAM read and output calculation
                sign_bit1 <= phase_accumulator(31); -- Store Top bit : 0 for 0-180 degrees, 1 for 180-360 degrees
                frac_bit1 <= std_logic_vector(phase_accumulator(20 downto 17)); -- Use 4 bits as fractional bit for interpolation (512 entry LUT)
            end if;
        end if;
    end process;

    BRAM_READ_PROC : process(clk)
    begin
        if rising_edge(clk) then
            -- Read from block RAM and delay sign bit
            y1_out <= std_logic_vector(to_unsigned(sine_lut(addr1), 10));
            y2_out <= std_logic_vector(to_unsigned(sine_lut(addr2), 10));
            sign_bit2 <= sign_bit1; -- Delay sign bit by 2 clock cycle to align with BRAM output
            frac_bit2 <= frac_bit1; -- Delay fractional bits by 2 clock cycle to align with BRAM output
        end if;
    end process;
end nco;